# Copie este arquivo para .env e preencha os valores antes de rodar o sistema.
# O arquivo .env NUNCA deve ser commitado no Git (já está no .gitignore).

# Banco de dados (padrão: SQLite local)
# Em desenvolvimento: deixe como está ou use um caminho personalizado.
# Em produção (Railway/Render): defina o caminho do arquivo SQLite persistente.
DATABASE_URL=estoque.db

# Senha do usuário admin criada ao executar reset_sistema.py
ADMIN_PASSWORD=troque_para_uma_senha_segura

# Ambiente de execução: "development" (padrão) ou "production"
# Em production, o cookie de sessão exige HTTPS (secure=True).
# Defina como "production" ao fazer deploy no Render/Railway.
ENVIRONMENT=development
